<svg width="512" height="512" xmlns="http://www.w3.org/2000/svg">
  <!-- Background -->
  <rect width="512" height="512" fill="#1a1a2e" rx="80"/>
  
  <!-- Outer glow ring -->
  <circle cx="256" cy="256" r="200" fill="none" stroke="#00d9ff" stroke-width="8" opacity="0.3"/>
  
  <!-- Main circle -->
  <circle cx="256" cy="256" r="180" fill="#0f3460" stroke="#00d9ff" stroke-width="4"/>
  
  <!-- Grid pattern (16 pads) -->
  <g fill="#00d9ff" opacity="0.6">
    <rect x="180" y="180" width="30" height="30" rx="4"/>
    <rect x="220" y="180" width="30" height="30" rx="4"/>
    <rect x="260" y="180" width="30" height="30" rx="4"/>
    <rect x="300" y="180" width="30" height="30" rx="4"/>
    
    <rect x="180" y="220" width="30" height="30" rx="4"/>
    <rect x="220" y="220" width="30" height="30" rx="4"/>
    <rect x="260" y="220" width="30" height="30" rx="4"/>
    <rect x="300" y="220" width="30" height="30" rx="4"/>
    
    <rect x="180" y="260" width="30" height="30" rx="4"/>
    <rect x="220" y="260" width="30" height="30" rx="4"/>
    <rect x="260" y="260" width="30" height="30" rx="4"/>
    <rect x="300" y="260" width="30" height="30" rx="4"/>
    
    <rect x="180" y="300" width="30" height="30" rx="4"/>
    <rect x="220" y="300" width="30" height="30" rx="4"/>
    <rect x="260" y="300" width="30" height="30" rx="4"/>
    <rect x="300" y="300" width="30" height="30" rx="4"/>
  </g>
  
  <!-- Text: DrC -->
  <text x="256" y="400" font-family="Arial, sans-serif" font-size="80" font-weight="bold" fill="#00d9ff" text-anchor="middle">DrC</text>
  
  <!-- Subtitle -->
  <text x="256" y="440" font-family="Arial, sans-serif" font-size="24" fill="#888" text-anchor="middle">Drum Machine</text>
</svg>
